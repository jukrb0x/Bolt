{
  "name": "bolt",
  "author": "Jabriel <jabrielah@outlook.com>",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/main.ts",
    "test": "bun test --env-file .env.local",
    "build:win": "bun build src/main.ts --compile --target=bun-windows-x64  --outfile=build/bolt-win-x64.exe",
    "build:mac": "bun build src/main.ts --compile --target=bun-darwin-arm64  --outfile=build/bolt-mac-arm64",
    "build:all": "bun run build:win && bun run build:mac"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "citty": "^0.2.1",
    "picocolors": "^1.1.1",
    "zod": "^3"
  }
}
